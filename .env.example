PORT=3001
NODE_ENV=production

# Option 1 — URL complète (Railway)
DATABASE_URL=postgresql://user:password@host:port/dbname

# Option 2 — Variables séparées (local)
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=edusmartdb
# DB_USERNAME=postgres
# DB_PASSWORD=

JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d
